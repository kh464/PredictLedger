generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id
  username  String   @unique
  balance   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bets    Bet[]
  ledgers Ledger[]
}

model Bet {
  id        Int       @id @default(autoincrement())
  userId    Int
  gameId    String
  amount    Int
  status    String    @default("PLACED")
  result    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  ledgers Ledger[]

  @@index([userId])
  @@index([status])
}

model Ledger {
  id             Int        @id @default(autoincrement())
  userId         Int
  betId          Int?
  type           String
  amount         Int
  refType        String
  refId          String
  idempotencyKey String?
  createdAt      DateTime   @default(now())

  user User @relation(fields: [userId], references: [id])
  bet  Bet? @relation(fields: [betId], references: [id])

  @@index([userId])
  @@index([betId])
  @@index([type])
  @@index([refType, refId])
}

model IdempotencyRecord {
  id             Int      @id @default(autoincrement())
  scope          String
  key            String
  requestHash    String
  responseStatus Int
  responseBody   String
  resourceType   String?
  resourceId     String?
  createdAt      DateTime @default(now())

  @@unique([scope, key])
}
